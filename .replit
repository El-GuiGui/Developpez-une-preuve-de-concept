run = "streamlit run streamlit_app_dashboard.py --server.port 8080 --server.address 0.0.0.0 --server.headless true"

[env]
PROJ_ROOT = "/home/runner/${REPL_SLUG}"

[nix]
channel = "stable-23_11"

[deployment]
run = ["sh", "-c", "streamlit run streamlit_app_dashboard.py --server.port 8080 --server.address 0.0.0.0 --server.headless true --server.enableCORS false --server.enableXsrfProtection false"]

[[ports]]
localPort = 8080
externalPort = 80